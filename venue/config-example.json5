{
	/*
	 * The core configuration is a list of venues to host on this server.
	 *
	 * Each venue gets:
	 * - It's own port
	 * - A globally unique DID
	 * - Separately configured Adapters
	 *
	 * Normally, one venue is sufficient. 
	 */
	"venues":[
		// First venue
		{
			"name":"Local Test Venue",
			"did":"did:covia:local",
			"hostname":"localhost",
			"port":8080,
			// "baseUrl": "https://venue.example.com",  // Override base URL (default: derived from hostname + port)

			// Configure MCP server capabilities
			"mcp":{
				"enabled":true
			},

			// Configure adapters
			"adapters":{

			},

			// Configure authentication and access control
			"auth":{
				// Allow unauthenticated access to API endpoints (default: false)
				"public":{ "enabled": true },

				// "tokenExpiry": 86400,  // JWT expiry in seconds (default 24 hours)

				// Configure OAuth login providers
				// "oauth":{
				// 	"google":{ "clientId": "YOUR_GOOGLE_CLIENT_ID", "clientSecret": "YOUR_GOOGLE_CLIENT_SECRET" },
				// 	"microsoft":{ "clientId": "YOUR_MS_CLIENT_ID", "clientSecret": "YOUR_MS_CLIENT_SECRET" },
				// 	"github":{ "clientId": "YOUR_GITHUB_CLIENT_ID", "clientSecret": "YOUR_GITHUB_CLIENT_SECRET" }
				// }
			},

			// Configure content storage
			// "content": "lattice" - CRDT-backed storage (default), syncs across venues
			// "content": "memory" - Simple in-memory storage, data lost on restart
			// "content": "file" - Filesystem storage, requires "path" to be set
			// "content": "dlfs" - DLFS lattice filesystem (local, replication pending)
			"storage":{
				"content":"lattice"
				// "path": "./content"  // Required for "file" and "dlfs" storage types
			}
		}
	],
	
	// Whole-server configuration goes here
	"convex": {
		// Config for embedded Convex peer, shared between venue instances
	}
}