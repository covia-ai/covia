{
  "name": "Extract Secret",
  "description": "Retrieve a secret from the caller's per-user secret store. Currently requires a capability grant (not yet implemented).",
  "operation": {
    "adapter": "secret:extract",
    "secretFields": ["value"],
    "input": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Secret name to retrieve" }
      },
      "required": ["name"]
    },
    "output": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "string", "description": "Decrypted secret value" }
      }
    }
  }
}
