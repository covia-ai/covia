{
  "name": "Set Secret",
  "description": "Store an encrypted secret in the caller's per-user secret store. The secret value is redacted in the job record.",
  "operation": {
    "adapter": "secret:set",
    "secretFields": ["value"],
    "input": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Secret name (e.g. OPENAI_API_KEY)" },
        "value": { "type": "string", "description": "Secret value to store" }
      },
      "required": ["name", "value"]
    },
    "output": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Secret name" },
        "stored": { "type": "boolean", "description": "Whether the secret was stored successfully" }
      }
    }
  }
}
