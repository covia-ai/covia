{
  "name": "Read DLFS File",
  "description": "Read file contents from a DLFS drive. Returns text (UTF-8) or base64-encoded content for binary files, plus file size.",
  "creator": "Covia",
  "operation": {
    "adapter": "dlfs:read",
    "input": {
      "type": "object",
      "properties": {
        "drive": { "type": "string", "description": "Drive name" },
        "path": { "type": "string", "description": "File path within the drive" }
      },
      "required": ["drive", "path"]
    },
    "output": {
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "File content (text or base64)" },
        "encoding": { "type": "string", "description": "utf-8 or base64" },
        "size": { "type": "integer", "description": "Size in bytes" }
      }
    }
  }
}
