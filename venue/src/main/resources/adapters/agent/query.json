{
	"name": "Query Agent",
	"description": "Reads an agent's current state, including status, config, tasks, pending jobs, inbox, timeline, and error. Returns the full agent record for the authenticated user's agent.",
	"dateCreated": "2026-03-06T00:00:00Z",
	"operation": {
		"adapter": "agent:query",
		"input": {
			"type": "object",
			"properties": {
				"agentId": { "type": "string", "description": "Agent name to query" }
			},
			"required": ["agentId"]
		},
		"output": {
			"type": "object",
			"properties": {
				"agentId": { "type": "string" },
				"status": { "type": "string" },
				"config": { "type": "object" },
				"state": { "description": "User-defined agent state (opaque)" },
				"tasks": { "type": "array", "description": "Inbound task Job IDs" },
				"pending": { "type": "array", "description": "Outbound pending Job IDs" },
				"inbox": { "type": "array", "description": "Pending inbox messages" },
				"timeline": { "type": "array", "description": "Transition history" },
				"error": { "type": "string", "description": "Last error, if any" }
			}
		}
	}
}
